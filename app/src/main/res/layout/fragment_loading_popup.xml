<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <LinearLayout
            android:id="@+id/linear_layout_on_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white">

            <TextView
                android:id="@+id/text_view_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/text_view_loading"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:paddingBottom="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/text_view_please_wait"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/text_view_please_wait"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:paddingBottom="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear_layout_on_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_view_response"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/text_view_response"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:paddingBottom="10dp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/button_close"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/button_close"
                android:textColor="@color/black"
                android:backgroundTint="@color/gray"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>