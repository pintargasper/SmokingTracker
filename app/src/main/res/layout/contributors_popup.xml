<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_contributors_popup_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/popup_contributors_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/settings_category_about_contributors"
            style="@style/MainTitleCenterTextView"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/popup_contributors_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/contributors_popup_info"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            style="@style/BodyTextView"
            app:layout_constraintTop_toBottomOf="@id/popup_contributors_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ScrollView
            android:id="@+id/contributors_scroll_container"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_marginTop="12dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/popup_contributors_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/contributor_1_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/contributor_1_website"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="pintargasper"
                        style="@style/SubtitleTextView"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/contributor_1_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contributors_popup_slovenian"
                        style="@style/BodyTextView" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/contributor_2_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/contributor_2_website"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="mrtaxi"
                        style="@style/SubtitleTextView"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/contributor_2_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contributors_popup_ukrainian"
                        style="@style/BodyTextView" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/contributor_3_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/contributor_3_website"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="jocixlinux-sys"
                        style="@style/SubtitleTextView"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/contributor_3_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contributors_popup_serbian"
                        style="@style/BodyTextView" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/contributor_4_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/contributor_4_website"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="iaanneed"
                        style="@style/SubtitleTextView"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/contributor_4_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contributors_popup_russian"
                        style="@style/BodyTextView" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/contributor_5_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/contributor_5_website"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ywnzzl"
                        style="@style/SubtitleTextView"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/contributor_5_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contributors_popup_chinese_simplified"
                        style="@style/BodyTextView" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_close_contributors_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:padding="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/contributors_scroll_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintWidth_max="320dp">

            <Button
                android:id="@+id/button_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/popup_close"
                style="@style/Button"/>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>